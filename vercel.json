{
    "version": 2,
    "builds": [
        {
            "src": "api/index.php",
            "use": "@vercel/php"
        },
        {
            "src": "public/assets/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/assets/(.*)",
            "dest": "/public/assets/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "SPREADSHEET_ID": "@spreadsheet_id",
        "GOOGLE_SERVICE_ACCOUNT_JSON": "@google_service_account_json",
        "SESSION_SECRET": "@session_secret",
        "ADMIN_USERNAME": "@admin_username",
        "ADMIN_PASSWORD": "@admin_password"
    }
}
